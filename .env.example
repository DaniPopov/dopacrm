# DopaCRM — Environment Variables
# Copy this file to .env.dev and fill in real values.
# See docs/standards/env.md for full documentation.

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
APP_SERVICE_NAME=backend
APP_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://root:root@mongo:27017/?authSource=admin
MONGODB_DATABASE=dopacrm

# ── PostgreSQL ───────────────────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql+asyncpg://dopacrm:dopacrm@postgres:5432/dopacrm
NEON_DIRECT_URL=postgresql://dopacrm:dopacrm@postgres:5432/dopacrm

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=dopacrm-uploads

# ── Sentry (optional) ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Flower ───────────────────────────────────────────────────────────────────
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=
