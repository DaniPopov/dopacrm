# DopaCRM — Environment Variables.
# Copy to ``.env.dev`` and fill in real values. See docs/standards/env.md.
# Optional knobs (APP_ENV, APP_DEBUG, log level, Sentry, Flower auth, ...)
# all have defaults in app/core/config.py — set them only to override.

APP_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters

DATABASE_URL=postgresql+asyncpg://dopacrm:dopacrm@postgres:5432/dopacrm

REDIS_URL=redis://redis:6379/0

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=dopacrm-uploads
